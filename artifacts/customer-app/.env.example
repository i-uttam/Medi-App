# MediGo Customer App — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# ── Supabase (required) ────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# ── API server (optional — only needed when testing API integration) ───────────
EXPO_PUBLIC_DOMAIN=your-replit-dev-domain

# ── Feature flags ──────────────────────────────────────────────────────────────

# TEMPORARY DEVELOPMENT FEATURE — DO NOT ENABLE FOR PRODUCTION RELEASE.
# Set to "true" to show the "Continue with Email" option on the Login screen.
# This enables real Supabase Email + Password auth for development / testing
# without requiring SMS OTP on every session.
# Default: false (disabled when absent or not exactly "true")
EXPO_PUBLIC_ENABLE_TEMPORARY_EMAIL_AUTH=false
