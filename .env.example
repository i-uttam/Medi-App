# =============================================================================
# Environment Variables — Online Pharmacy Platform
# =============================================================================
# IMPORTANT: Copy this file to .env for local development.
# NEVER commit real credentials to this file or any Git-tracked file.
# All production secrets must be added to Replit Secrets (never here).
# =============================================================================

# =============================================================================
# SUPABASE — CLI & Server-side (Replit Secrets only — NEVER in client bundles)
# =============================================================================

# Supabase Personal Access Token (for CLI non-interactive auth)
# Obtain from: https://supabase.com/dashboard/account/tokens
# NEVER commit this value. Add to Replit Secrets as SUPABASE_ACCESS_TOKEN.
SUPABASE_ACCESS_TOKEN=

# Supabase database password (for supabase db push / supabase link)
# Found in Supabase Dashboard → Project Settings → Database → Password
# NEVER commit this value. Add to Replit Secrets as SUPABASE_DB_PASSWORD.
SUPABASE_DB_PASSWORD=

# Supabase project reference ID (e.g. "abcdefghijklmnop")
# Found in Supabase Dashboard → Project Settings → General → Reference ID
# Safe to commit (not a secret). Add to Replit Secrets as SUPABASE_PROJECT_ID.
SUPABASE_PROJECT_ID=

# Supabase project URL (public — safe for server-side code)
# Format: https://<project-ref>.supabase.co
SUPABASE_URL=

# Supabase Service Role Key (SERVER-SIDE ONLY — bypasses all RLS)
# NEVER expose in client apps (Expo, browser). Edge Functions only.
# Found in Supabase Dashboard → Project Settings → API → service_role
# Add to Replit Secrets as SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# SUPABASE — Client-safe keys (Expo mobile app)
# =============================================================================

# Customer mobile app (Expo React Native)
# EXPO_PUBLIC_ prefix makes these available in the Expo bundle (safe — subject to RLS)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# =============================================================================
# SUPABASE — Client-safe keys (Next.js admin panel, if/when built)
# =============================================================================

# Admin web panel (Next.js)
# NEXT_PUBLIC_ prefix makes these available in the browser bundle (safe — subject to RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# =============================================================================
# API SERVER (Express)
# =============================================================================

# PostgreSQL connection string (Supabase pooled connection URL)
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Found in Supabase Dashboard → Project Settings → Database → Connection string (Transaction mode)
DATABASE_URL=

# Session secret for Express session middleware
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# =============================================================================
# NOTES
# =============================================================================
# publishable_key is the new Supabase key name for the anon key.
# If your Supabase project uses the legacy "anon key" label, use that value
# for EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY and NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
#
# DO NOT add:
#   - SUPABASE_ACCESS_TOKEN (server-only — Replit Secret)
#   - SUPABASE_DB_PASSWORD (server-only — Replit Secret)
#   - SUPABASE_SERVICE_ROLE_KEY (server-only — never in .env)
# to any EXPO_PUBLIC_ or NEXT_PUBLIC_ variable.
